# CMake out-of-source build dirs
build/
build-*/
cmake-build-*/

# Artefacts left in-source by the libc/libbsd cross-build (which the
# legacy GNU-make rules write next to the sources, not in CMake's
# build dir).
libc/*.a
libc/*.o
libc/**/*.o
libc/**/*.a
libc/include/linuxmt
libc/include/arch
# Generated by each libc subdir's Makefile `transfer:` target -- copies of
# libc/{stdio,string,malloc,regexp}/<header>.h. Upstream removed them
# from version control in Dev86src-0.16.6 / 0.16.11 because they're
# regenerated at build time.
libc/include/stdio.h
libc/include/string.h
libc/include/malloc.h
libc/include/regexp.h
libc/include/regmagic.h
libc/syscall/syscall.c
libc/syscall/syscall.dat
libc/syscall/syscall.mak
libc/syscall/call_tab.v
libc/syscall/defn_tab.v
libc/.config.dir
libc/.config.lst
libc/.config.tmp
libc/.config.dep
libc/*/.config.dep
libbsd/*.a
libbsd/*.o

# Editor / OS junk
.DS_Store
*.swp
.fuse_hidden*
